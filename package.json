{
  "name": "aftertaste-fm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:adapter": "npm --prefix apps/netease-adapter run dev",
    "dev:server": "cd services/radio-server && ./gradlew run",
    "build:web": "npm --prefix apps/web run build",
    "build:adapter": "npm --prefix apps/netease-adapter run build",
    "build:server": "cd services/radio-server && ./gradlew build",
    "analyze:playlist": "node scripts/analyze-playlist-openai.mjs",
    "build:profile": "node scripts/build-taste-profile.mjs"
  }
}
