# Radio server
PORT=8080
HOST_LANGUAGE=en-US
HOST_VOICE_STYLE=calm-late-night
HOST_NAME=Aftertaste
MUSIC_PROVIDER=mock
NETEASE_ADAPTER_BASE_URL=http://localhost:8090

# Web
VITE_RADIO_API_BASE=http://localhost:8080

# Netease adapter
ADAPTER_PORT=8090
NETEASE_COOKIE=
NETEASE_API_BASE=
# true = local mock data. false = bundled NeteaseCloudMusicApi package unless NETEASE_API_BASE is set.
MOCK_NETEASE=true

# Optional runtime LLM planner. Without a key the server falls back to the mock planner.
# LLM_PROVIDER=openai | openai-compatible | anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5.2
LLM_CHAT_MODEL=gpt-5.2
LLM_TEMPERATURE=0.75
# Offline playlist analysis currently calls the OpenAI Responses API using LLM_API_KEY.
ANALYSIS_MODEL=gpt-5.2
ANALYSIS_BATCH_SIZE=12
# Runtime planner sends only this many selected candidates to the LLM.
LLM_CANDIDATE_LIMIT=30
# Local state and memory database. Runtime writes messages, plays, plans, prefs, and current state here.
STATE_DB_PATH=services/radio-server/data/state.db

# Weather context. If OPENWEATHER_API_KEY is set, radio-server uses OpenWeather.
# Without a key it falls back to Open-Meteo so the prototype remains runnable.
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_GEO_BASE_URL=https://api.openweathermap.org/geo/1.0
OPENWEATHER_UNITS=metric
OPENWEATHER_LANG=en

# Optional Fish Audio TTS. Without FISH_API_KEY, host voice falls back to text-only.
FISH_API_KEY=
FISH_TTS_ENDPOINT=https://api.fish.audio/v1/tts
FISH_TTS_MODEL=s2-pro
# Pick a voice/model id from Fish Audio. If blank, the request is still attempted and may fail depending on Fish defaults.
FISH_VOICE_ID=
FISH_TTS_FORMAT=mp3
FISH_TTS_LATENCY=normal
FISH_TTS_TEMPERATURE=0.7
FISH_TTS_TOP_P=0.7
# false = generate fresh voice files for each new show. true = reuse identical script/model/voice audio.
FISH_TTS_CACHE=false
FISH_TTS_SPEED=1.0
FISH_TTS_VOLUME=4.0
FISH_TTS_SAMPLE_RATE=44100
FISH_TTS_MP3_BITRATE=128
FISH_TTS_MAX_NEW_TOKENS=1024
FISH_TTS_REPETITION_PENALTY=1.2
TTS_CACHE_DIR=cache/tts
